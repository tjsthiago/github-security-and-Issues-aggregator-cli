{
  "name": "github-issues-dependabot-aggregator",
  "version": "0.1.0",
  "description": "CLI tool to fetch and aggregate GitHub Issues and Dependabot Alerts into Markdown reports",
  "main": "dist/cli.js",
  "bin": {
    "aggregator": "dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node dist/cli.js",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "keywords": [
    "github",
    "issues",
    "dependabot",
    "security",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
